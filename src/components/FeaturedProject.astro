---
import type { FeaturedProject } from '@/data/projects';
import { translations, type Lang } from '@/i18n/translations';

interface Props {
  project: FeaturedProject;
  lang: Lang;
}

const { project, lang } = Astro.props;
const t = translations[lang].projects;

const appStoreUrl = project.appStoreUrl
  ? (lang === 'en' ? project.appStoreUrl.replace('/br/', '/en/') : project.appStoreUrl)
  : undefined;

const category = lang === 'en' ? project.categoryEn : project.category;
const description = lang === 'en' ? project.descriptionEn : project.description;
const highlights = lang === 'en' ? (project.highlightsEn ?? project.highlights) : project.highlights;
---

<div class="featured-card">
  <span class="featured-badge">{t.featuredBadge}</span>

  <div class="featured-preview">
    {project.image && (
      <img src={project.image} alt={project.imageAlt ?? project.title} class="preview-image" loading="eager" />
    )}
    {project.demoUrl && (
      <iframe
        src={project.demoUrl}
        class="preview-frame"
        loading="lazy"
        tabindex="-1"
        aria-hidden="true"
        title={`${project.title} — live preview`}
        sandbox="allow-scripts allow-same-origin"
      ></iframe>
    )}
    {!project.image && !project.demoUrl && (
      <>
        <div class="preview-grid" aria-hidden="true"></div>
        <div class="preview-icon">{project.icon}</div>
      </>
    )}
    {(project.image || project.demoUrl) && (
      <div class="preview-overlay" aria-hidden="true"></div>
    )}
  </div>

  <div class="featured-body">
    <p class="featured-category">{category}</p>
    <h3 class="featured-title">{project.title}</h3>
    <p class="featured-desc">{description}</p>

    {highlights && highlights.length > 0 && (
      <ul class="featured-highlights">
        {highlights.map((h) => (
          <li>{h}</li>
        ))}
      </ul>
    )}

    <div class="featured-tags">
      {project.tech.map((t) => <span class="tag">{t}</span>)}
    </div>

    <div class="featured-links">
      {project.demoUrl && (
        <a href={project.demoUrl} target="_blank" rel="noopener noreferrer" class="link-demo">
          {t.accessApp}
        </a>
      )}
      {appStoreUrl && (
        <a href={appStoreUrl} target="_blank" rel="noopener noreferrer" class="store-badge" aria-label="Download on the App Store">
          <svg viewBox="0 0 120 40" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <rect width="120" height="40" rx="6" fill="#000"/>
            <text x="38" y="13" font-family="-apple-system,sans-serif" font-size="7" fill="#fff" opacity="0.8">Download on the</text>
            <text x="38" y="27" font-family="-apple-system,sans-serif" font-size="13" font-weight="600" fill="#fff">App Store</text>
            <path d="M18 8.5c1.6-2 4-2.3 4-2.3s.3 2.2-1.3 4.3c-1.7 2.2-3.7 1.9-3.7 1.9s-.4-1.9 1-3.9zm-1 5c.9 0 2.6-1.2 4.8-1.2 3.8 0 5.3 2.7 5.3 2.7s-2.9 1.5-2.9 5.3c0 4.2 3.7 5.7 3.7 5.7s-2.6 7.2-6.1 7.2c-1.6 0-2.9-1.1-4.6-1.1-1.7 0-3.4 1.1-4.6 1.1C9 33.2 6 26.1 6 21.1c0-5.7 3.5-8.7 6.9-8.7 1.8 0 3.2 1.1 4.1 1.1z" fill="#fff"/>
          </svg>
        </a>
      )}
      {project.githubUrl && (
        <a href={project.githubUrl} target="_blank" rel="noopener noreferrer" class="link-github">GitHub</a>
      )}
    </div>
  </div>
</div>

<style>
  .featured-card {
    display: block;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(167, 139, 250, 0.2);
    border-radius: 20px;
    overflow: hidden;
    position: relative;
    color: inherit;
    transition: transform 0.25s ease, border-color 0.25s ease, box-shadow 0.25s ease;
    box-shadow:
      0 0 60px rgba(124, 58, 237, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.06);
  }

  .featured-card:hover {
    transform: translateY(-2px);
    border-color: rgba(167, 139, 250, 0.4);
    box-shadow:
      0 8px 80px rgba(124, 58, 237, 0.22),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .featured-badge {
    position: absolute;
    top: 16px;
    left: 16px;
    background: linear-gradient(135deg, #7c3aed, #2563eb);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 100px;
    z-index: 2;
  }

  .featured-preview {
    width: 100%;
    height: 300px;
    background: linear-gradient(135deg, #1a0533, #0c1445, #050d2b);
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    overflow: hidden;
  }

  .preview-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
    z-index: 0;
  }

  .preview-frame {
    position: absolute;
    top: 0;
    left: 0;
    width: 250%;
    height: 250%;
    border: 0;
    pointer-events: none;
    transform: scale(0.4);
    transform-origin: 0 0;
    background: transparent;
    z-index: 1;
    opacity: 0;
    animation: previewFadeIn 0.4s ease 0.6s forwards;
  }

  .featured-card:hover .preview-frame { pointer-events: auto; }

  @keyframes previewFadeIn {
    to { opacity: 1; }
  }

  @media (prefers-reduced-motion: reduce) {
    .preview-frame { animation: none; opacity: 1; }
  }

  .preview-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(5, 13, 43, 0) 60%,
      rgba(5, 13, 43, 0.7) 100%
    );
    pointer-events: none;
    z-index: 2;
  }

  .preview-grid {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 40px,
        rgba(167, 139, 250, 0.03) 40px,
        rgba(167, 139, 250, 0.03) 41px
      ),
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent 40px,
        rgba(167, 139, 250, 0.03) 40px,
        rgba(167, 139, 250, 0.03) 41px
      );
  }

  .preview-icon {
    font-size: 40px;
    width: 72px;
    height: 72px;
    border-radius: 16px;
    background: linear-gradient(135deg, #7c3aed, #06b6d4);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 40px rgba(124, 58, 237, 0.4);
    position: relative;
    z-index: 1;
  }

  .featured-body { padding: 20px 24px 24px; }

  .featured-category {
    font-size: 10px;
    color: var(--primary);
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 8px;
  }

  .featured-title {
    font-size: 22px;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text);
  }

  .featured-desc {
    font-size: 13px;
    color: var(--text-dim);
    line-height: 1.6;
    margin-bottom: 14px;
  }

  .featured-highlights {
    list-style: none;
    padding: 0;
    margin: 0 0 16px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6px 14px;
  }

  .featured-highlights li {
    font-size: 12px;
    color: var(--text-muted);
    position: relative;
    padding-left: 14px;
  }

  .featured-highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 7px;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: linear-gradient(135deg, #a78bfa, #34d399);
  }

  .featured-tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 16px;
  }

  .featured-links {
    display: flex;
    gap: 10px;
    align-items: center;
    font-size: 13px;
    font-weight: 600;
    flex-wrap: wrap;
  }

  .link-demo {
    color: var(--primary);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .link-demo:hover { opacity: 0.8; }

  .store-badge {
    display: inline-flex;
    border-radius: 6px;
    overflow: hidden;
    transition: opacity 0.2s ease, transform 0.2s ease;
    border: 1px solid rgba(255, 255, 255, 0.12);
  }

  .store-badge:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .store-badge svg {
    display: block;
    height: 32px;
    width: auto;
  }

  .link-github {
    color: var(--text-muted);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .link-github:hover { opacity: 0.8; }

  @media (max-width: 768px) {
    .featured-preview { height: 240px; }
    .featured-highlights { grid-template-columns: 1fr; }
  }
</style>
